@using System.Globalization
@inject Internal.ResourceCache cache
@inject Internal.ILocalStorageAccessor localStorageAccessor
@inject IResourceProvider resourceProvider
@inject Microsoft.Extensions.Options.IOptions<BlazorLocalizerOptions> options

@if (_hasLoaded)
{
    @_displayValue
}
else if(options.Value.ShowKeyAsPlaceholder)
{
    @Key
}
@if (options.Value.DebugMode)
{
    <span style="display: none">@Category</span>
}

@code {
    [Parameter]
    public string Key { get; set; }

    [Parameter]
    public string Category { get; set; }

    [Parameter]
    public string CultureName { get; set; }

    private string _displayValue;

    private bool _hasLoaded = false;

    protected override void OnInitialized()
    {
        // Try synchronous memory cache lookup first to avoid a second render
        if (!string.IsNullOrWhiteSpace(Key))
        {
            var culture = CultureName;
            if (string.IsNullOrWhiteSpace(culture))
            {
                culture = cache.CachedCultureName;
            }
            if (!string.IsNullOrWhiteSpace(culture) && cache.TryGetResourceSync(Key, culture, Category, out var value))
            {
                _displayValue = value;
                _hasLoaded = true;
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // If already resolved synchronously, skip the async fetch
        if (_hasLoaded)
        {
            return;
        }

        if(!string.IsNullOrWhiteSpace(Key))
        {
            var culture = CultureName;
            if (string.IsNullOrWhiteSpace(culture))
            {
                culture = await cache.GetOrResolveCultureName(resourceProvider);
            }
            _displayValue = await cache.GetResource(Key, culture, Category, resourceProvider, localStorageAccessor);
            _hasLoaded = true;
            this.StateHasChanged();
        }
    }
}
